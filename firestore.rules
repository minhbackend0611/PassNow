rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Quy tắc cho collection users
    match /users/{userId} {
      // Bất kỳ ai đăng nhập đều có thể xem profile người khác
      allow read: if request.auth != null;
      // Chỉ chủ sở hữu mới có quyền tạo/sửa profile của chính mình
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Quy tắc cho collection listings (sản phẩm)
    match /listings/{listingId} {
      // Bất kỳ ai cũng có thể xem sản phẩm
      allow read: if true;
      // Chỉ người đăng nhập mới được tạo sản phẩm, và chỉ chủ sản phẩm mới được sửa/xóa
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // Quy tắc cho collection chats
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
